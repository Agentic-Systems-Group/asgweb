---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;

const title = "Mneme has moved — Agentic Systems Group";
const description = "Mneme has been superseded on this site by EdMneme.";
---

<BaseLayout {title} {description}>
  <div class="page-shell">
    <section class="hero-band redirect-shell">
      <p class="eyebrow">Archive</p>
      <h1 class="display display--tight">Mneme has been replaced here by EdMneme.</h1>
      <p class="redirect-copy">
        The current site no longer treats Mneme as the primary product surface.
        For the tutoring and control-room stack now on the site, go to EdMneme.
      </p>
      <div class="actions">
        <a class="button" href="/edmneme">Open EdMneme</a>
        <a class="ghost-button" href="/">Return home</a>
      </div>
    </section>
  </div>
</BaseLayout>
