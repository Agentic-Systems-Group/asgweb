---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;

const title = "CivSim has been folded into current research — Agentic Systems Group";
const description = "Earlier CivSim framing now lives inside broader research directions including Zeta.";
---

<BaseLayout {title} {description}>
  <div class="page-shell">
    <section class="hero-band redirect-shell">
      <p class="eyebrow">Archive</p>
      <h1 class="display display--tight">CivSim is no longer a primary public track.</h1>
      <p class="redirect-copy">
        The current site points to the research page and to Zeta for the live simulation-heavy work.
      </p>
      <div class="actions">
        <a class="button" href="/research">Open research</a>
        <a class="ghost-button" href="/zeta">Open Zeta</a>
      </div>
    </section>
  </div>
</BaseLayout>
